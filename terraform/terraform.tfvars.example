# terraform/terraform.tfvars
# Copy this file and fill in your values

# DigitalOcean API token (create at: https://cloud.digitalocean.com/profile/api_tokens)
do_token = "your-digitalocean-token"

# SSH key fingerprint (get with: doctl compute ssh-key list)
ssh_key_fingerprint = "your-ssh-key-fingerprint"

# Preferred regions (will auto-select first available)
# Available: atl1, nyc1, sfo2, ams3, sgp1, blr1, lon1
preferred_regions = ["atl1", "nyc1", "sfo2", "ams3"]